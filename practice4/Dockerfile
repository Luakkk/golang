# ---- builder ----
FROM golang:1.25.5-alpine AS builder

WORKDIR /app
COPY go.mod ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -trimpath -ldflags="-s -w" -o myapp ./cmd/api/main.go

# ---- final ----
FROM alpine:3.20

RUN adduser -D -g '' appuser
WORKDIR /

COPY --from=builder /app/myapp /myapp

USER appuser
EXPOSE 8080
ENTRYPOINT ["/myapp"]
